{
  "name": "@hidock/connectors-slack",
  "version": "0.1.0",
  "description": "HiDock Slack connector — LLM-free delta sync of channels (living md captures + image artifacts), user→contact identity, and send-message action, against the connector-host contract",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@hidock/connectors": "file:../connectors"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
