{
  "name": "@hidock/knowledge-graph",
  "version": "0.1.0",
  "description": "GraphRAG core: entity/relation extraction from meeting transcripts, SQLite-backed knowledge graph",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@hidock/database": "file:../database",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/sql.js": "1.4.9",
    "better-sqlite3": "^12.11.1",
    "sql.js": "^1.11.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
