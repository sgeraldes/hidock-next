{
  "version": 1,
  "providers": {
    "google": {
      "name": "Google Gemini",
      "audioCapable": true,
      "models": [
        {
          "id": "gemini-2.5-flash",
          "name": "Gemini 2.5 Flash",
          "description": "Fast & cost-effective",
          "costMultiplier": 1,
          "contexts": ["realtime", "draft", "batch"],
          "capabilities": ["audio", "multimodal", "streaming"],
          "recommended": true
        },
        {
          "id": "gemini-3.0-pro",
          "name": "Gemini 3.0 Pro",
          "description": "Higher quality for critical meetings",
          "costMultiplier": 10,
          "contexts": ["critical", "final", "important"],
          "capabilities": ["audio", "multimodal", "streaming", "enhanced-analysis"]
        },
        {
          "id": "gemini-2.0-flash",
          "name": "Gemini 2.0 Flash (Deprecated)",
          "description": "Legacy model",
          "costMultiplier": 1,
          "deprecated": true,
          "contexts": [],
          "capabilities": ["audio", "multimodal", "streaming"],
          "migratesTo": "gemini-2.5-flash",
          "sunset": "2026-06-01"
        }
      ],
      "defaultModel": "gemini-2.5-flash"
    },
    "openai": {
      "name": "OpenAI",
      "audioCapable": false,
      "models": [
        {
          "id": "gpt-4o",
          "name": "GPT-4o",
          "costMultiplier": 15,
          "contexts": ["default"],
          "capabilities": ["text", "vision"]
        }
      ],
      "defaultModel": "gpt-4o",
      "requiresTranscription": true,
      "transcriptionProvider": "google"
    }
  },
  "contexts": {
    "realtime": { "name": "Real-time", "priority": "speed" },
    "postprocess": { "name": "Post-Processing", "priority": "quality" },
    "critical": { "name": "Critical Meetings", "priority": "quality" },
    "batch": { "name": "Batch Processing", "priority": "cost" }
  }
}
